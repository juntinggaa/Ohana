# 复制此文件为 .env 并填入真实密钥（.env 不会进 git）
# Copy this file to .env and fill in real keys (.env is gitignored)

# DeepSeek 官方 API · platform.deepseek.com
# 走 deepseek-v4-flash 模型 · OpenAI 兼容接口
VITE_DEEPSEEK_API_KEY=

# OpenRouter 备选通道 · openrouter.ai/keys
# 若同时设置两个 Key，应用会优先使用 OpenRouter
VITE_OPENROUTER_API_KEY=

# OCR.space · ocr.space/ocrapi
# 免费档单文件需 ≤ 1 MB · 每月 25,000 次额度
VITE_OCR_SPACE_API_KEY=

# ─────────────────────────────────────────────────────────
# 老 OCR 变量名（保留以兼容旧 .env） · 设了新变量后可留空
VITE_MISTRAL_API_KEY=
